# .env.example — Copy to .env and fill in real values. Never commit .env.
# All keys are free-tier registrations.

# Finnhub — https://finnhub.io (free tier: 60 calls/min)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpaca Markets — https://alpaca.markets (free data plan: 200 req/min)
# Used as primary price-history source (SIP consolidated tape, split-adjusted).
# Paper-trading keys work — no live trading needed.
ALPACA_API_KEY_ID=your_alpaca_key_id_here
ALPACA_API_SECRET_KEY=your_alpaca_secret_key_here

# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# SEC EDGAR (edgartools) — required for get_filings() and transcript fallback
# Format: "Your Name your@email.com" (SEC policy: must identify the requester)
SEC_EDGAR_USER_AGENT=Your Name your@email.com

# Optional overrides for state directory paths (defaults shown)
# LEDGER_DB_PATH=state/ledger.db
# MEMORY_DIR=state/memory/
# DEBATES_DIR=state/debates/

# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
