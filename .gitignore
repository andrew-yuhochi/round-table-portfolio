# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/

# Secrets
.env

# SQLite ledger and all runtime state — local-only, never committed
state/

# Config files with real values (only *.example.yaml are committed)
config/*.yaml
config/*.toml
!config/*.example.yaml
!config/streamlit_theme.toml
# sp500_universe.yaml is public S&P 500 data (no PII) — version-controlled in
# the mega-repo so the loader works on a fresh checkout. It is NOT on the
# GitHub publish whitelist (.github-publish.txt lists only *.example.yaml),
# so it stays off the public GitHub repo.
!config/sp500_universe.yaml

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/
